# Database connection (PostgreSQL URL or Npgsql connection string)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# JWT signing key (must be at least 32 characters, keep secret)
Jwt__Key=your-secret-key-at-least-32-characters-long

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.azurestaticapps.net

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Development
